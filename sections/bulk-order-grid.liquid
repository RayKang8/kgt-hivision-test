<div class="page-width bulk-order-{{ section.id }}">
  <div class="section-header text-center">
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}
      <div class="rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>

  {%- assign matched_count = 0 -%}
  {%- capture table_head -%}{%- endcapture -%}
  {%- capture table_body -%}{%- endcapture -%}

  {%- if section.settings.collection != blank -%}
    {%- paginate section.settings.collection.products by 250 -%}
      {%- for product in section.settings.collection.products -%}
        {%- if section.settings.tag == blank or product.tags contains section.settings.tag -%}
          {%- assign matched_count = matched_count | plus: 1 -%}

          {%- if matched_count == 1 -%}
            {%- capture table_head -%}
              {%- for variant in product.variants -%}
                <th><span class="bulk-order-table__variant-chip">{{ variant.title }}</span></th>
              {%- endfor -%}
            {%- endcapture -%}
          {%- endif -%}

          {%- capture row -%}
            <tr>
              <td class="bulk-order-table__product-col">
                <div class="bulk-order-product">
                  {%- if product.featured_image -%}
                    <img
                      class="bulk-order-product__image"
                      src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}"
                      alt=""
                      width="40"
                      height="40"
                      loading="lazy">
                  {%- endif -%}
                  <span class="bulk-order-product__title">{{ product.title }}</span>
                </div>
              </td>
              {%- for variant in product.variants -%}
                <td>
                  {%- if variant.available -%}
                    {%- assign caps_quantity = false -%}
                    {%- if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' -%}
                      {%- assign caps_quantity = true -%}
                    {%- endif -%}
                    <div class="bulk-order-stepper">
                      <button type="button" class="bulk-order-stepper__btn" data-step="-1" aria-label="Decrease quantity">&minus;</button>
                      <input
                        type="number"
                        inputmode="numeric"
                        min="0"
                        {%- if caps_quantity %}
                        max="{{ variant.inventory_quantity }}"
                        title="Only {{ variant.inventory_quantity }} left"
                        {%- endif %}
                        step="1"
                        value="0"
                        class="bulk-order-table__input"
                        data-variant-id="{{ variant.id }}"
                        data-label="{{ product.title }} {{ variant.title }}"
                        aria-label="{{ product.title }} {{ variant.title }} quantity">
                      <button type="button" class="bulk-order-stepper__btn" data-step="1" aria-label="Increase quantity">&plus;</button>
                    </div>
                  {%- else -%}
                    <span class="bulk-order-table__soldout">Sold out</span>
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endcapture -%}
          {%- assign table_body = table_body | append: row -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endpaginate -%}
  {%- endif -%}

  {%- if matched_count == 0 -%}
    <p class="text-center">
      No products found. Pick a collection for this section in the theme editor, and make sure it contains products tagged &ldquo;{{ section.settings.tag }}&rdquo;.
    </p>
  {%- else -%}
    <div class="bulk-order-card" data-bulk-order-root="{{ section.id }}">
      <div class="bulk-order-table-wrapper">
        <table class="bulk-order-table">
          <thead>
            <tr>
              <th class="bulk-order-table__product-col">Style</th>
              {{ table_head }}
            </tr>
          </thead>
          <tbody>
            {{ table_body }}
          </tbody>
        </table>
      </div>

      <div class="bulk-order-table__actions">
        <span class="bulk-order-table__summary" data-bulk-order-summary></span>
        <button type="button" class="btn" data-bulk-order-submit>{{ section.settings.button_label }}</button>
      </div>
      <div class="bulk-order-table__status" data-bulk-order-status role="status"></div>
    </div>
  {%- endif -%}
</div>

<style>
  .bulk-order-{{ section.id }} .bulk-order-card {
    margin-top: 2em;
    background-color: var(--color-bg-alt, #fff);
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 24px;
  }

  .bulk-order-{{ section.id }} .bulk-order-table-wrapper {
    overflow-x: auto;
  }

  .bulk-order-{{ section.id }} .bulk-order-table {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
    min-width: 560px;
  }

  .bulk-order-{{ section.id }} .bulk-order-table th,
  .bulk-order-{{ section.id }} .bulk-order-table td {
    padding: 12px 14px;
    text-align: center;
    border-bottom: 1px solid var(--color-border, #e6e6e6);
  }

  .bulk-order-{{ section.id }} .bulk-order-table thead th {
    font-family: var(--font-stack-header, inherit);
    font-size: 0.8em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-body-text, #666);
    font-weight: normal;
    border-bottom-width: 2px;
    white-space: nowrap;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__variant-chip {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    background-color: var(--color-bg, #f2f2f2);
  }

  .bulk-order-{{ section.id }} .bulk-order-table__product-col {
    text-align: left;
    white-space: nowrap;
    position: sticky;
    left: 0;
    background-color: var(--color-bg-alt, #fff);
    z-index: 1;
  }

  .bulk-order-{{ section.id }} .bulk-order-table tbody tr:hover td {
    background-color: var(--color-bg, #fafafa);
  }

  .bulk-order-{{ section.id }} .bulk-order-table tbody tr:hover .bulk-order-table__product-col {
    background-color: var(--color-bg, #fafafa);
  }

  .bulk-order-{{ section.id }} .bulk-order-product {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .bulk-order-{{ section.id }} .bulk-order-product__image {
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .bulk-order-{{ section.id }} .bulk-order-product__title {
    font-weight: var(--font-weight-header, 600);
  }

  .bulk-order-{{ section.id }} .bulk-order-stepper {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--color-border-form, #ccc);
    border-radius: 4px;
    overflow: hidden;
    background-color: var(--color-text-field, #fff);
  }

  .bulk-order-{{ section.id }} .bulk-order-stepper__btn {
    -webkit-appearance: none;
    appearance: none;
    border: none;
    background: transparent;
    color: var(--color-text-field-text, #333);
    width: 28px;
    line-height: 1;
    font-size: 1em;
    cursor: pointer;
  }

  .bulk-order-{{ section.id }} .bulk-order-stepper__btn:hover {
    background-color: var(--color-bg, #f2f2f2);
  }

  .bulk-order-{{ section.id }} .bulk-order-stepper__btn:active {
    background-color: var(--color-border, #e6e6e6);
  }

  .bulk-order-{{ section.id }} .bulk-order-table__input {
    -moz-appearance: textfield;
    appearance: none;
    width: 44px;
    border: none;
    border-left: 1px solid var(--color-border-form, #ccc);
    border-right: 1px solid var(--color-border-form, #ccc);
    text-align: center;
    padding: 6px 2px;
    background-color: var(--color-text-field, #fff);
    color: var(--color-text-field-text, #333);
    font-size: 1em;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__input::-webkit-outer-spin-button,
  .bulk-order-{{ section.id }} .bulk-order-table__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__input:focus {
    outline: none;
    box-shadow: inset 0 0 0 1px var(--color-text-focus, #000);
  }

  .bulk-order-{{ section.id }} .bulk-order-table__soldout {
    display: inline-block;
    font-size: 0.85em;
    color: var(--color-body-text, #999);
    opacity: 0.65;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__actions {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
    flex-wrap: wrap;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__summary {
    font-size: 0.9em;
    color: var(--color-body-text, #666);
  }

  .bulk-order-{{ section.id }} .bulk-order-table__status {
    margin-top: 10px;
    font-size: 0.9em;
    color: var(--color-body-text, #666);
    min-height: 1.2em;
  }

  .bulk-order-{{ section.id }} .bulk-order-table__status.is-error {
    color: var(--color-sale-text, #c0392b);
  }

  @media only screen and (max-width: 749px) {
    .bulk-order-{{ section.id }} .bulk-order-card {
      padding: 16px;
    }
  }
</style>

<script>
  (function() {
    var root = document.querySelector('[data-bulk-order-root="{{ section.id }}"]');
    if (!root) return;

    var button = root.querySelector('[data-bulk-order-submit]');
    var status = root.querySelector('[data-bulk-order-status]');
    var summary = root.querySelector('[data-bulk-order-summary]');

    var clampMessageTimeout;

    function showMaxReachedMessage(input, max) {
      var label = input.getAttribute('data-label') || 'this item';
      status.textContent = 'Only ' + max + ' in stock for ' + label + ' — quantity adjusted.';
      status.classList.add('is-error');
      clearTimeout(clampMessageTimeout);
      clampMessageTimeout = setTimeout(function() {
        status.textContent = '';
        status.classList.remove('is-error');
      }, 4000);
    }

    function clampInput(input) {
      var value = parseInt(input.value, 10);
      if (isNaN(value)) return;

      var max = input.getAttribute('max');
      if (value < 0) {
        input.value = 0;
      } else if (max !== null && value > parseInt(max, 10)) {
        input.value = max;
        showMaxReachedMessage(input, max);
      }
    }

    function updateSummary() {
      var inputs = root.querySelectorAll('input[data-variant-id]');
      var styles = 0;
      var units = 0;

      inputs.forEach(function(input) {
        var qty = parseInt(input.value, 10) || 0;
        if (qty > 0) {
          styles += 1;
          units += qty;
        }
      });

      summary.textContent = units > 0
        ? units + ' unit' + (units === 1 ? '' : 's') + ' across ' + styles + ' line' + (styles === 1 ? '' : 's')
        : '';
    }

    root.addEventListener('input', function(event) {
      var input = event.target;
      if (!input.matches('input[data-variant-id]')) return;
      clampInput(input);
      updateSummary();
    });

    // The browser silently blocks the number input's keyboard up-arrow once
    // `max` is reached, without firing an `input` event — needs its own message.
    root.addEventListener('keydown', function(event) {
      var input = event.target;
      if (!input.matches('input[data-variant-id]')) return;
      if (event.key !== 'ArrowUp') return;

      var max = input.getAttribute('max');
      if (max === null) return;

      var value = parseInt(input.value, 10) || 0;
      if (value >= parseInt(max, 10)) {
        showMaxReachedMessage(input, max);
      }
    });

    root.addEventListener('click', function(event) {
      var stepBtn = event.target.closest('.bulk-order-stepper__btn');
      if (!stepBtn) return;

      var step = parseInt(stepBtn.getAttribute('data-step'), 10);
      var input = stepBtn.parentElement.querySelector('input[data-variant-id]');
      var value = (parseInt(input.value, 10) || 0) + step;
      var max = input.getAttribute('max');

      if (value < 0) {
        value = 0;
      } else if (max !== null && value > parseInt(max, 10)) {
        value = parseInt(max, 10);
        showMaxReachedMessage(input, max);
      }

      input.value = value;
      updateSummary();
    });

    button.addEventListener('click', function() {
      var inputs = root.querySelectorAll('input[data-variant-id]');
      var items = [];

      inputs.forEach(function(input) {
        var qty = parseInt(input.value, 10);
        if (qty > 0) {
          items.push({
            id: parseInt(input.getAttribute('data-variant-id'), 10),
            quantity: qty
          });
        }
      });

      if (items.length === 0) {
        status.textContent = 'Enter a quantity greater than 0 in at least one field.';
        status.classList.add('is-error');
        return;
      }

      button.disabled = true;
      status.classList.remove('is-error');
      status.textContent = 'Adding to cart…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ items: items })
      })
        .then(function(response) {
          if (!response.ok) {
            return response.json().then(function(err) {
              throw new Error(err.description || err.message || 'Could not add items to cart.');
            });
          }
          return response.json();
        })
        .then(function() {
          window.location.href = '/cart';
        })
        .catch(function(err) {
          button.disabled = false;
          status.textContent = err.message;
          status.classList.add('is-error');
        });
    });
  })();
</script>

{% schema %}
{
  "name": "Bulk order grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bulk Order"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description text"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Pick the collection whose products should appear as rows in the grid."
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Required tag filter",
      "default": "bulk",
      "info": "Only products in the collection above that also have this tag will be shown. Leave blank to disable tag filtering."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart button label",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Bulk order grid"
    }
  ]
}
{% endschema %}
